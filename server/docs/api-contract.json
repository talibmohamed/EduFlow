        "email": "string",
        "password": "string",
        "role": "child|parent|teacher"
      },
      "successStatus": 201,
      "successShape": {
        "success": true,
        "message": "string",
        "data": {
          "token": "string",
          "user": {
            "id": "number",
            "name": "string",
            "email": "string",
            "role": "string"
          }
        }
      },
      "errors": [
        {
          "status": 400,
          "message": "<field> invalid"
        },
        {
          "status": 409,
          "message": "Email already registered"
        }
      ]
    },
    {
      "method": "POST",
      "path": "/api/auth/login",
