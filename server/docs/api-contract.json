{
  "version": "0.5.0",
  "lastUpdated": "2026-06-06",
  "baseUrl": "http://localhost:5000",
  "roles": ["child", "parent", "teacher"],
  "endpoints": [
    {
      "method": "GET",
      "path": "/",
      "auth": false,
      "allowedRoles": ["public"],
      "requestBody": null,
      "successStatus": 200,
      "successShape": {
        "success": true,
        "message": "string"
      },
      "errors": []
    },
    {
      "method": "POST",
      "path": "/api/auth/register",
      "auth": false,
      "allowedRoles": ["public"],
      "requestBody": {
        "name": "string",
        "email": "string",
        "password": "string",
        "role": "child|parent|teacher"
      },
      "successStatus": 201,
      "successShape": {
        "success": true,
        "message": "string",
        "data": {
          "token": "string",
          "user": {
            "id": "number",
            "name": "string",
            "email": "string",
            "role": "string"
          }
        }
      },
      "errors": [
        {
          "status": 400,
          "message": "<field> invalid"
        },
        {
          "status": 409,
          "message": "Email already registered"
        }
      ]
    },
    {
      "method": "POST",
      "path": "/api/auth/login",
      "auth": false,
      "allowedRoles": ["public"],
      "requestBody": {
        "oneOf": [
          { "email": "string", "password": "string" },
          { "username": "string", "pin": "string (4 digits)" }
        ]
      },
      "successStatus": 200,
      "successShape": {
        "success": true,
        "message": "string",
        "data": {
          "token": "string",
          "user": {
            "id": "number",
            "name": "string",
            "email": "string|null",
            "username": "string|null",
            "role": "string"
          }
        }
      },
      "errors": [
        { "status": 400, "message": "Provide either email+password or username+pin" },
        { "status": 400, "message": "Provide only one credential pair" },
        { "status": 400, "message": "PIN must be 4 digits" },
        { "status": 401, "message": "Invalid credentials" }
      ]
    },
    {
      "method": "GET",
      "path": "/api/auth/me",
      "auth": true,
      "allowedRoles": ["authenticated"],
      "requestBody": null,
      "successStatus": 200,
      "successShape": {
        "success": true,
        "data": {
          "user": {
            "id": "number",
            "name": "string",
            "email": "string|null",
            "username": "string|null",
            "role": "string"
          }
        }
      },
      "errors": [
        {
          "status": 401,
          "message": "Authentication required"
        }
      ]
    },
    { "method": "POST", "path": "/api/daily-state", "auth": true, "allowedRoles": ["child"],
      "requestBody": { "energy_level": "low|medium|high", "focus_level": "low|medium|high" },
      "successStatus": 201,
      "successShape": { "success": true, "message": "string", "data": { "dailyState": "object" } },
      "errors": [ { "status": 400, "message": "<field> invalid" }, { "status": 409, "message": "Daily state already set for today" } ] },
    { "method": "GET", "path": "/api/daily-state/me", "auth": true, "allowedRoles": ["child"],
      "requestBody": null, "successStatus": 200,
      "successShape": { "success": true, "data": { "dailyState": "object|null" } }, "errors": [] },
    { "method": "GET", "path": "/api/child/adapted-homework", "auth": true, "allowedRoles": ["child"],
      "requestBody": null, "successStatus": 200,
      "successShape": { "success": true, "data": { "dailyState": "object", "homework": "array" } },
      "errors": [ { "status": 409, "message": "Daily state required for today" } ] },
    { "method": "GET", "path": "/api/child/homework/:id", "auth": true, "allowedRoles": ["child"],
      "requestBody": null, "successStatus": 200,
      "successShape": { "success": true, "data": { "homework": "object" } },
      "errors": [ { "status": 404, "message": "Homework not found" } ] },
    { "method": "PATCH", "path": "/api/tasks/:id/complete", "auth": true, "allowedRoles": ["child"],
      "requestBody": null, "successStatus": 200,
      "successShape": { "success": true, "message": "string", "data": { "task": "object" } },
      "errors": [ { "status": 404, "message": "Task not found" } ] },
    { "method": "PATCH", "path": "/api/tasks/:id/postpone", "auth": true, "allowedRoles": ["child"],
      "requestBody": null, "successStatus": 200,
      "successShape": { "success": true, "message": "string", "data": { "task": "object" } },
      "errors": [ { "status": 404, "message": "Task not found" } ] },
    { "method": "GET", "path": "/api/child/progress", "auth": true, "allowedRoles": ["child"],
      "requestBody": null, "successStatus": 200,
      "successShape": { "success": true, "data": { "completed": "number", "postponed": "number", "message": "string" } },
      "errors": [] },
    {
      "method": "GET",
      "path": "/api/parent/children",
      "auth": true,
      "allowedRoles": ["parent"],
      "requestBody": null,
      "successStatus": 200,
      "successShape": {
        "success": true,
        "data": {
          "children": [
            {
              "id": "number",
              "name": "string",
              "username": "string",
              "age": "number|null",
              "classLevel": "string|null"
            }
          ]
        }
      },
      "errors": []
    },
    {
      "method": "POST",
      "path": "/api/parent/children",
      "auth": true,
      "allowedRoles": ["parent"],
      "requestBody": {
        "name": "string (2-120)",
        "username": "string (3-60, [a-z0-9_-])",
        "pin": "string (4 digits)",
        "age": "integer 4-18 (optional)",
        "class_level": "string (optional, <=40)"
      },
      "successStatus": 201,
      "successShape": {
        "success": true,
        "message": "string",
        "data": {
          "child": {
            "id": "number",
            "name": "string",
            "username": "string",
            "age": "number|null",
            "classLevel": "string|null"
          }
        }
      },
      "errors": [
        { "status": 400, "message": "name invalid" },
        { "status": 400, "message": "username invalid" },
        { "status": 400, "message": "PIN must be 4 digits" },
        { "status": 400, "message": "age invalid (must be 4-18)" },
        { "status": 400, "message": "class_level invalid" },
        { "status": 409, "message": "Username already taken" }
      ]
    },{
      "method": "GET",
      "path": "/api/parent/children/:id/daily-states",
      "auth": true,
      "allowedRoles": ["parent"],
      "requestBody": null,
      "successStatus": 200,
      "successShape": {
        "success": true,
        "data": {
          "dailyStates": [
            {
              "id": "number",
              "date": "string (YYYY-MM-DD)",
              "energy_level": "low|medium|high",
              "focus_level": "low|medium|high"
            }
          ]
        }
      },
      "errors": [
        { "status": 403, "message": "Access denied" },
        { "status": 404, "message": "Child not found" }
      ]
    },
    {
      "method": "GET",
      "path": "/api/parent/children/:id/progress",
      "auth": true,
      "allowedRoles": ["parent"],
      "requestBody": null,
      "successStatus": 200,
      "successShape": {
        "success": true,
        "data": {
          "today": {
            "completed": "number",
            "postponed": "number"
          },
          "week": {
            "completed": "number",
            "postponed": "number"
          }
        }
      },
      "errors": [
        { "status": 403, "message": "Access denied" },
        { "status": 404, "message": "Child not found" }
      ]
    }
  ]
}